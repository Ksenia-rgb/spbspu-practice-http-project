            "name": "Bob",
            "active": false
          }
        ]
      }
    }
  },
  {
    "name": "create_user",
    "mark": "post",
    "comment": "создание нового пользователя",
    "request": {
      "method": "POST",
      "host": "api.test.com",
      "path": "/users",
      "headers": [
        "Content-Type: application/json",
        "Authorization: Bearer token123"
      ],
      "body": {
        "name": "Charlie",
        "age": 21,
        "email": "charlie@example.com",
        "roles": [
          "user",
          "admin"
        ],
        "profile": {
          "city": "Saint Petersburg",
          "country": "RU"
        }
      }
    },
    "response": {
      "status": 201,
      "headers": [
        "Content-Type: application/json"
      ],
      "body": {
        "id": 1001,
        "created": true
      }
    }
  },
  {
    "name": "update_user",
    "mark": "put",
    "comment": "частичное обновление данных",
    "request": {
      "method": "PUT",
      "host": "api.test.com",
      "path": "/users/1001",
      "headers": [
        "Content-Type: application/json"
      ],
      "body": {
        "name": "Charlie Updated",
        "age": 22,
        "active": false,
        "tags": [
          "vip",
          "beta",
          "test"
        ]
      }
    },
    "response": {
      "status": 200,
      "headers": [
        "Content-Type: application/json"
      ],
      "body": {
        "success": true,
        "updatedFields": [
          "name",
          "age",
          "active"
        ]
      }
    }
  },
