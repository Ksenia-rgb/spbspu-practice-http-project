  {
    "name": "login",
    "mark": "auth",
    "comment": "авторизация пользователя",
    "request": {
      "method": "POST",
      "host": "auth.test.com",
      "path": "/login",
      "headers": [
        "Content-Type: application/json"
      ],
      "body": {
        "username": "test_user",
        "password": "pass1234"
      }
    },
    "response": {
      "status": 200,
      "headers": [
        "Content-Type: application/json",
        "Set-Cookie: sessionId=abc123"
      ],
      "body": {
        "token": "jwt.token.here",
        "expiresIn": 3600
      }
    }
  },
  {
    "name": "refresh_token",
    "mark": "auth",
    "comment": "обновление токена",
    "request": {
      "method": "POST",
      "host": "auth.test.com",
      "path": "/refresh",
      "headers": [
        "Authorization: Bearer old_token"
      ],
      "body": {
        "refreshToken": "refresh_token_value"
      }
    },
    "response": {
      "status": 200,
      "headers": [
        "Content-Type: application/json"
      ],
      "body": {
        "token": "new.jwt.token",
        "expiresIn": 3600
      }
    }
  },
