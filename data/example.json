  {
    "name": "get_users",
    "mark": "smoke",
    "comment": "получение списка пользователей",
    "request": {
      "method": "GET",
      "host": "api.test.com",
      "path": "/users",
      "headers": [
        "Accept: application/json",
        "Authorization: Bearer token123"
      ],
      "body": {}
    },
